# StudyFlow Frontend Environment Variables
# Copy this file to .env and adjust as needed

# Backend API base URL — use one of:
# Local:  http://localhost (docker-compose up)
# Ngrok:  https://unfixable-apron-pointy.ngrok-free.dev (deployed)
VITE_API_URL=http://localhost

# Use mock data instead of real backend (true/false)
# Set to false when docker-compose is running
VITE_USE_MOCKS=true

# Skip ngrok browser warning header (set to false in production)
VITE_NGROK_SKIP_WARNING=true

# Dev initData for testing TMA auth outside Telegram (optional)
# Get a real initData string from Telegram Mini App debug mode
# or use the dev login form on the welcome page
# VITE_DEV_TELEGRAM_INIT_DATA=query_id=...&user=...&auth_date=...&hash=...
